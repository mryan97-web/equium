{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions granted to the main window: invoke our own commands, clipboard write, open external links.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "opener:allow-open-url",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default"
  ]
}
